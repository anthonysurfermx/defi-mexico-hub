# ============================================================
# OnchainOS × OpenClaw — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# OnchainOS / OKX API Credentials
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here
OKX_PROJECT_ID=your_project_id_here

# Safety Switches
ENABLE_LIVE_TRADING=false
MAX_POSITION_USDC=100
MIN_DIVERGENCE_THRESHOLD=3

# Polymarket (proxied via vercel.json rewrites)
POLYMARKET_API_BASE=https://clob.polymarket.com
GAMMA_API_BASE=https://gamma-api.polymarket.com

# AI Analysis (existing)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase (existing)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
