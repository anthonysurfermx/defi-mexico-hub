{
  "rewrites": [
    { "source": "/bobby", "destination": "/agentic-world/bobby/challenge" },
    { "source": "/api/polymarket-gamma/:path*", "destination": "https://gamma-api.polymarket.com/:path*" },
    { "source": "/api/polymarket-data/:path*", "destination": "https://data-api.polymarket.com/:path*" },
    { "source": "/api/polymarket-clob/:path*", "destination": "https://clob.polymarket.com/:path*" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/api/polymarket-data/v1/leaderboard",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/polymarket-data/positions",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/polymarket-gamma/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=60" }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/openclaw-chat.ts": { "maxDuration": 60 },
    "api/bobby-intel.ts": { "maxDuration": 30 },
    "api/bobby-cycle.ts": { "maxDuration": 60 },
    "api/mcp-bobby.ts": { "maxDuration": 60 }
  }
}
